generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


// enum para los estados de la transaccion
enum EstadoTransaccion {
  PENDIENTE
  APROBADA
  FALLIDA
  CANCELADA
}

model Transaccion {
  id_transaccion     Int               @id @default(autoincrement())
  id_pedido          Int               @unique
  monto              Int
  moneda             String            @default("ARS")

  estado_transaccion EstadoTransaccion @default(PENDIENTE)

  id_comprador       String            // ID de Clerk
  id_vendedor        String            // ID de Clerk

  id_preferencia_pago String?
  id_pago_proveedor   String?
  estado_proveedor    String?
  referencia_pago     String?          @unique

  creado_en         DateTime          @default(now())
  actualizado_en    DateTime          @updatedAt
  venta             Venta?

  @@index([id_comprador, estado_transaccion, creado_en])
  @@index([id_vendedor, estado_transaccion, creado_en])
}

model Vendedor {
  id_vendedor String   @id // ID de Clerk
  nombre      String
  email       String   @unique
  ventas      Venta[]
  creado_en   DateTime @default(now())
}



model Venta {
  id_venta              Int         @id @default(autoincrement())
  fecha_venta           DateTime    @default(now())

  id_transaccion        Int         @unique
  transaccion           Transaccion @relation(fields: [id_transaccion], references: [id_transaccion])

  id_vendedor           String
  vendedor              Vendedor    @relation(fields: [id_vendedor], references: [id_vendedor])

  monto_bruto           Int         @default(0)
  porcentaje_comision   Decimal     @default(12.00) @db.Decimal(5, 2)
  monto_comision        Int         @default(0)
  monto_neto_vendedor   Int         @default(0)
  moneda                String      @default("ARS")
}
