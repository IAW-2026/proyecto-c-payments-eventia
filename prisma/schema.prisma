generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Transaccion {
  id_transaccion     Int      @id @default(autoincrement())
  estado_transaccion String
  id_pedido          Int
  creado_en          DateTime @default(now())
  actualizado_en     DateTime @updatedAt
}